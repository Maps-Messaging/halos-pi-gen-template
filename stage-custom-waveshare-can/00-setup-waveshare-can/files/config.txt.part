
# Waveshare 2-Channel Isolated CAN HAT — CH0 only.
# SPI0 has two chip-select lines: CS0 (GPIO 8) and CS1 (remapped by HALPI2
# to GPIO 6 for the onboard MCP251xFD). CH0 takes CS0; CH1 has nowhere to
# land without moving to SPI1 with a custom overlay.
dtoverlay=mcp2515-can0,oscillator=16000000,interrupt=25
